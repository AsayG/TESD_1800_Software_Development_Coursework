		class checkingAccounts extends Account {
			private double limit;
		 public checkingAccounts(int id, double balance, double limit) {
				super(id, balance);
				
				this.limit = limit;
			}
		 
		 public void withdraw(double amount) {
			 if (amount > 0 && (balance + limit) >= amount) {
				 balance -= amount;
			 }
			 
		 }
		public String toString() {
				 return "Checking " + super.toString() + "Withdrawl Limit: $" + limit + "";
			 }
		 
		}
	
	
		
