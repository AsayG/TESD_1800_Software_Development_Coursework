package outOfBounds;

import javafx.animation.Animation;
import javafx.animation.FadeTransition;
import javafx.animation.PathTransition;
import javafx.animation.Timeline;
import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.layout.Pane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Rectangle;
import javafx.scene.shape.Circle;
import javafx.scene.shape.Polygon;
import javafx.stage.Stage;
import javafx.util.Duration;

public class OutOfBounds extends Application {
  @Override 
  	public void start(Stage primaryStage) {

	  Pane pane = new Pane();
	  
	  Rectangle rectangle = new Rectangle(0, 0, 25, 50);
	  rectangle.setFill(Color.TEAL);
	  FadeTransition ft = new FadeTransition(Duration.millis(3000), rectangle);
	  ft.setFromValue(1.0); // Opaque
	  ft.setToValue(0.1);   // Transparent
	  ft.setCycleCount(Animation.INDEFINITE);
	  ft.setAutoReverse(true);
	  ft.play();
    
	  Polygon pentagon = new Polygon();
	  double radius = 100; 
	  double centerX = 150;
	  double centerY = 150;

	  for (int i = 0; i < 5; i++) {
	      double angle = Math.toRadians(-90 + i * 360.0 / 5);
	      double x = centerX + radius * Math.cos(angle);
	      double y = centerY + radius * Math.sin(angle);
	      pentagon.getPoints().addAll(x, y);
	  }
	  pentagon.setFill(Color.WHITE);
	  pentagon.setStroke(Color.BLACK);
    
    
	  pane.getChildren().add(pentagon);
	  pane.getChildren().add(rectangle);
    
    // Create a path transition 
    PathTransition pt = new PathTransition();
    pt.setDuration(Duration.millis(4000));
    pt.setPath(pentagon);
    pt.setNode(rectangle);
    pt.setOrientation(
      PathTransition.OrientationType.ORTHOGONAL_TO_TANGENT);
    pt.setCycleCount(Timeline.INDEFINITE);
    //pt.setAutoReverse(true);
    pt.play(); // Start animation 
    
    pentagon.setOnMousePressed(e -> pt.pause());
    pentagon.setOnMouseReleased(e -> pt.play());
    
    // Create a scene and place it in the stage
    Scene scene = new Scene(pane, 300, 300);
    primaryStage.setTitle("Rectangle and Pentagon"); // Set the stage title
    primaryStage.setScene(scene); // Place the scene in the stage
    primaryStage.show(); // Display the stage
  }
  
 
}
